RESTIC_REPOSITORY=/repo
RESTIC_PASSWORD=test-password
BACKUP_CRON=* * * * *
CHECK_CRON=*/2 * * * *
BACKUP_PATH=/data
CHECK_ARGS=--read-data-subset=1/1
RESTIC_BACKUP_ARGS=--verbose --one-file-system
RESTIC_FORGET_ARGS=--keep-last 5 --prune
PING_URL_BACKUP=http://ping:8080/backup
PING_URL_CHECK=http://ping:8080/check
